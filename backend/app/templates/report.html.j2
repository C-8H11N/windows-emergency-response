<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <title>{{ app_name }} 报告</title>
  <style>
    body{font-family:'Microsoft YaHei',Arial,sans-serif;background:#0f172a;color:#e2e8f0;margin:0;padding:32px} .card{background:#111827;border:1px solid #334155;border-radius:16px;padding:20px;margin:16px 0} h1,h2{color:#f8fafc}.sev-critical{color:#f87171}.sev-high{color:#fb923c}.sev-medium{color:#facc15}.sev-low{color:#60a5fa}.sev-info{color:#94a3b8} code{color:#a7f3d0;white-space:pre-wrap} @media print{body{background:white;color:#111}.card{border:1px solid #ccc;background:white}}
  </style>
</head>
<body>
  <h1>{{ app_name }} 综合应急排查报告</h1>
  <div class="card">
    <p>生成时间：{{ generated_at }}</p><p>主机名：{{ hostname }}</p><p>IP：{{ ips|join(', ') }}</p><p>系统：{{ os_version }}</p><p>管理员权限：{{ '是' if is_admin else '否' }}</p><p>工具版本：{{ version }}</p>
  </div>
  <div class="card"><h2>风险摘要</h2>{% for k,v in severity_counts.items() %}<span class="sev-{{k}}">{{k}}: {{v}}</span> {% endfor %}<p>扫描状态：{{ status.status }}，发现项总数：{{ status.findings|length }}</p></div>
  <div class="card"><h2>模块摘要</h2>{% for m in status.modules %}<h3>{{ m.display_name }} ({{ m.status }})</h3><p>{{ m.summary }}</p>{% if m.errors %}<code>{{ m.errors|join('\n') }}</code>{% endif %}{% endfor %}</div>
  <h2>详细发现</h2>
  {% for f in status.findings %}<div class="card"><h3 class="sev-{{f.severity.value}}">[{{ f.severity.value }}] {{ f.title }}</h3><p>{{ f.summary }}</p><p><b>建议：</b>{{ f.recommendation }}</p><p><b>证据：</b></p><code>{{ f.evidence|join('\n') }}</code></div>{% endfor %}
  <div class="card"><h2>处置操作记录</h2>{% if action_log %}<code>{{ action_log }}</code>{% else %}<p>无。</p>{% endif %}</div>
  <div class="card"><h2>免责声明</h2><p>本报告基于本机实时采集与启发式规则生成，不等同于最终定性结论。处置前请保全证据并结合业务环境复核。</p></div>
</body>
</html>
